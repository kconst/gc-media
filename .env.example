# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# ---------------------------------------------------------------------------

# --- AI analysis (Claude vision) ---
ANTHROPIC_API_KEY=

# --- Google Photos retrieval (OAuth) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Where the OAuth token is cached after the first login flow.
GOOGLE_OAUTH_TOKEN_PATH=./data/google-token.json

# --- AWS infra: TEMPORARY admin creds used ONLY by `terraform apply` ---
# These are short-lived STS credentials. Export them in your shell before
# running terraform; do not rely on them for the loader at runtime.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-west-2

# --- AWS media bucket (filled in from `terraform output` after apply) ---
# The loader uploads media using the SCOPED IAM keys below, not the admin creds.
MEDIA_BUCKET=
CLOUDFRONT_DOMAIN=
LOADER_AWS_ACCESS_KEY_ID=
LOADER_AWS_SECRET_ACCESS_KEY=

# --- Manifest publishing target (where the web app reads pins at runtime) ---
# "s3" publishes manifest.json to the media bucket and serves it via CloudFront.
MANIFEST_STORE=s3
MANIFEST_KEY=manifest.json

# --- Web app (apps/web) ---
# These NEXT_PUBLIC_* values are also set in the Vercel project settings.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
NEXT_PUBLIC_MANIFEST_URL=

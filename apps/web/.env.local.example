# Local dev for the web app. Copy to apps/web/.env.local
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# A Map ID is required for Advanced Markers (create one in Google Cloud console).
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Point at the bundled sample to try the UI before the loader has run:
NEXT_PUBLIC_MANIFEST_URL=/sample-manifest.json
